# ========================================
# Trading Command Center — Configuration
# ========================================

# --- API Authentication ---
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_KEY=your-random-api-key-here

# --- Database Paths (inside Docker) ---
WW_DB_PATH=/data/ww/trading.db
CH_DB_PATH=/data/ch/commodity.db
CRYPTO_DB_PATH=/data/crypto/crypto.db

# --- Frontend (set in Vercel environment variables) ---
# VITE_API_URL=https://your-droplet-domain:8090
# VITE_API_KEY=same-key-as-above
